{
    "version":  "0.2.0",
    "configurations":  [
                           {
                               "name":  "Debug: active file (gdb)",
                               "type":  "cppdbg",
                               "request":  "launch",
                               "program":  "${fileDirname}/${fileBasenameNoExtension}.exe",
                               "args":  [

                                        ],
                               "stopAtEntry":  false,
                               "cwd":  "${fileDirname}",
                               "environment":  [

                                               ],
                               "externalConsole":  true,
                               "MIMode":  "gdb",
                               "miDebuggerPath":  "D:/msys64/ucrt64/bin/gdb.exe",
                               "preLaunchTask":  "build: active file (c++20 + same-dir deps)",
                               "setupCommands":  [
                                                     {
                                                         "description":  "Enable pretty-printing for gdb",
                                                         "text":  "-enable-pretty-printing",
                                                         "ignoreFailures":  true
                                                     }
                                                 ]
                           }
                       ]
}
