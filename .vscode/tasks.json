{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build: active file (c++20 + same-dir deps)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "$active = (Resolve-Path '${file}').Path; $allCpp = Get-ChildItem -Path '${fileDirname}' -Filter '*.cpp' | ForEach-Object { $_.FullName }; $sources = @($active) + ($allCpp | Where-Object { $_ -ne $active }); & 'D:/msys64/ucrt64/bin/g++.exe' '-std=c++20' '-g' '-O0' '-Wall' '-Wextra' @sources '-o' '${fileDirname}/${fileBasenameNoExtension}.exe'"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "run: active file",
            "type": "shell",
            "command": "${fileDirname}/${fileBasenameNoExtension}.exe",
            "dependsOn": "build: active file (c++20 + same-dir deps)",
            "problemMatcher": []
        },
        {
            "type": "shell",
            "label": "C/C++: g++.exe build active file",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "$active = (Resolve-Path '${file}').Path; $allCpp = Get-ChildItem -Path '${fileDirname}' -Filter '*.cpp' | ForEach-Object { $_.FullName }; $sources = @($active) + ($allCpp | Where-Object { $_ -ne $active }); & 'D:/msys64/ucrt64/bin/g++.exe' '-std=c++20' '-fdiagnostics-color=always' '-g' @sources '-o' '${fileDirname}/${fileBasenameNoExtension}.exe'"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Task generated by Debugger."
        }
    ]
}
