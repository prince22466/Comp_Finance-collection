{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug FDM2D_demo (gdb)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}\\FDM2D_demo.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "D:\\msys64\\ucrt64\\bin\\gdb.exe",
            "preLaunchTask": "C/C++: g++.exe build FDM2D_demo",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}
